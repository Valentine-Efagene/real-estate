{
    "name": "@real-estate/local-dev",
    "version": "1.0.0",
    "private": true,
    "description": "Local development utilities for QShelter e2e testing with LocalStack",
    "main": "lib/index.ts",
    "scripts": {
        "start": "bash scripts/start.sh",
        "stop": "bash scripts/stop.sh",
        "reset": "bash scripts/reset.sh",
        "logs": "bash scripts/logs.sh",
        "migrate": "bash scripts/migrate.sh",
        "seed": "bash scripts/seed.sh",
        "setup": "bash scripts/setup.sh",
        "setup:full": "bash scripts/setup.sh && npm run test:e2e:mortgage",
        "build:shared": "cd ../shared/common && npm run build",
        "build:services": "for s in user property mortgage notification documents payment uploader; do cd ../services/${s}-service && npm run build && cd -; done",
        "build:all": "npm run build:shared && npm run build:services",
        "deploy:authorizer-api": "cd ../services/authorizer-api-dynamo && npm run deploy",
        "deploy:user": "cd ../services/user-service && npm run deploy:localstack",
        "deploy:property": "cd ../services/property-service && npm run deploy:localstack",
        "deploy:mortgage": "cd ../services/mortgage-service && npm run deploy:localstack",
        "deploy:notifications": "cd ../services/notification-service && npm run deploy:localstack",
        "deploy:documents": "cd ../services/documents-service && npm run deploy:localstack",
        "deploy:all": "npm run deploy:user && npm run deploy:property && npm run deploy:mortgage && npm run deploy:notifications && npm run deploy:documents",
        "test:e2e": "npm run start && npm run migrate && cd ../services/mortgage-service && npm run test:e2e",
        "test:e2e:mortgage": "cd ../services/mortgage-service && npm run test:e2e",
        "test:e2e:user": "cd ../services/user-service && npm run test:e2e",
        "test:e2e:localstack": "cd ../services/mortgage-service && npm run test:e2e:localstack",
        "test:e2e:localstack:all": "cd ../services/mortgage-service && npm run test:e2e:localstack:all",
        "test:e2e:localstack:chidi": "cd ../services/mortgage-service && npm run test:e2e:localstack:chidi",
        "test:e2e:localstack:payment-change": "cd ../services/mortgage-service && npm run test:e2e:localstack:payment-change",
        "test:e2e:localstack:property-transfer": "cd ../services/mortgage-service && npm run test:e2e:localstack:property-transfer",
        "test:e2e:localstack:jinx": "cd ../services/mortgage-service && npm run test:e2e:localstack:jinx",
        "test:authorizer": "AWS_ENDPOINT=http://localhost:4566 jest --config jest.config.js tests/authorizer.test.ts"
    },
    "dependencies": {
        "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
        "@aws-sdk/client-dynamodb": "^3.700.0",
        "@aws-sdk/client-eventbridge": "^3.700.0",
        "@aws-sdk/client-lambda": "^3.700.0",
        "@aws-sdk/client-s3": "^3.700.0",
        "@aws-sdk/client-secrets-manager": "^3.700.0",
        "@aws-sdk/client-sns": "^3.700.0",
        "@aws-sdk/client-sqs": "^3.700.0",
        "@aws-sdk/client-ssm": "^3.700.0",
        "@valentine-efagene/qshelter-common": "^2.0.216",
        "jsonwebtoken": "^9.0.2"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.10.2",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "typescript": "^5.7.2"
    }
}