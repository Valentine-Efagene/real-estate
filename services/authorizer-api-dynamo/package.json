{
    "name": "authorizer-api-dynamo",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Permissions CRUD API using Express, Zod, Swagger, TypeScript, esbuild, Serverless, and DynamoDB",
    "scripts": {
        "dev": "tsx watch src/local.ts",
        "start:dev": "tsx watch src/local.ts",
        "build": "tsc && node esbuild.config.js",
        "test": "node --experimental-vm-modules --no-warnings=ExperimentalWarning node_modules/jest/bin/jest.js --runInBand",
        "deploy": "npm run build && npx serverless deploy",
        "remove": "npx serverless remove"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.1.0",
        "@aws-sdk/client-dynamodb": "^3.910.0",
        "@aws-sdk/lib-dynamodb": "^3.910.0",
        "@codegenie/serverless-express": "^4.17.0",
        "dotenv": "^17.2.3",
        "express": "^4.21.2",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@types/aws-lambda": "^8.10.152",
        "@types/express": "^5.0.3",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.13.10",
        "@types/supertest": "^6.0.3",
        "@types/swagger-ui-express": "^4.1.8",
        "esbuild": "^0.25.1",
        "jest": "^29.7.0",
        "serverless": "^4.17.1",
        "serverless-offline": "^14.4.0",
        "supertest": "^7.1.0",
        "ts-jest": "^29.2.5",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}